# Circle.so Admin API v2 token (from Developers > Tokens in Circle dashboard)
CIRCLE_API_TOKEN=your_admin_api_token_here

# Your Circle community hostname (e.g. io-scholar.circle.so)
CIRCLE_COMMUNITY_HOST=your-community.circle.so

# Circle Headless Auth token (required for /community member UI)
# Create at: Circle Dashboard > Settings > Developers > Tokens > type "Headless Auth"
CIRCLE_HEADLESS_AUTH_TOKEN=your_headless_auth_token_here

# iron-session secret (must be at least 32 characters)
SESSION_PASSWORD=a_very_long_secret_at_least_32_chars

# Admin password hash (generate with: npm run hash-password)
ADMIN_PASSWORD_HASH=$2b$10$...your_bcrypt_hash_here
